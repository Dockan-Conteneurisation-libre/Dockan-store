#!/usr/bin/env sh
set -eu

root="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
cmd="${1:-}"

case "$cmd" in
  list|ls)
    exec "$root/scripts/list.sh"
    ;;
  install)
    shift
    exec "$root/scripts/install-app.sh" "$@"
    ;;
  update)
    shift
    exec "$root/scripts/update-app.sh" "$@"
    ;;
  images)
    shift
    exec "$root/scripts/prepare-images.sh" "$@"
    ;;
  pack-images)
    shift
    exec "$root/scripts/pack-images.sh" "$@"
    ;;
  build-images)
    shift
    exec "$root/scripts/build-images.sh" "$@"
    ;;
  export-app-images)
    shift
    exec "$root/scripts/export-app-registry.sh" "$@"
    ;;
  help|-h|--help|"")
    echo "Usage:"
    echo "  ./dockan-store list"
    echo "  ./dockan-store images <app-id|all> [registry-dir]"
    echo "  ./dockan-store install <app-id> [target-dir]"
    echo "  ./dockan-store update <app-id> [target-dir] [registry-dir]"
    echo "  ./dockan-store build-images <app-id|image-ref|all> [registry-dir]"
    echo "  ./dockan-store pack-images <app-id|all> [registry-dir]"
    echo "  ./dockan-store export-app-images <app-id> [registry-dir] [output.tar.gz]"
    echo
    echo "Examples:"
    echo "  ./dockan-store install static-site"
    echo "  ./dockan-store install static-site /srv/apps/static-site"
    echo "  ./dockan-store update static-site"
    echo "  ./dockan-store update static-site /srv/apps/static-site"
    echo "  ./dockan-store images wordpress"
    echo "  ./dockan-store build-images all"
    echo "  ./dockan-store build-images mysql:local"
    echo "  ./dockan-store export-app-images wordpress"
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo "Run: ./dockan-store help" >&2
    exit 1
    ;;
esac
